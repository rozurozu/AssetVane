# AssetVane 環境変数テンプレート
# このファイルをコピーして backend/.env を作成し、実際の値を記入する:
#   cp .env.example backend/.env
# .env 本体は git 管理対象外（.gitignore で除外）。

# --- J-Quants API (V2) ---
# ダッシュボードの「設定 » API キー」で発行したキー。
# V2 はトークン2段階方式ではなく、このキーを x-api-key ヘッダーで送るだけ。
JQUANTS_API_KEY=your_jquants_api_key_here

# --- データベース ---
# SQLite ファイルのパス（リポジトリ直下の data/ を想定）。
DATABASE_PATH=./data/assetvane.db

# --- 通知 (Discord) ---
# Discord チャンネルの Webhook URL（Phase 4 で使用）。
DISCORD_WEBHOOK_URL=

# --- 米国ETFデータソース (Phase 5 / 任意) ---
# リードラグ戦略で米国ETF日足を取得する場合の設定（ソース未確定のため将来用）。
# US_ETF_SOURCE=stooq
