# AssetVane 環境変数テンプレート
#
# バックエンド: このファイルをコピーして backend/.env を作成し、実際の値を記入する:
#   cp .env.example backend/.env
# フロントエンド: frontend/.env.local に NEXT_PUBLIC_* を記入する（末尾参照）。
# .env 本体は git 管理対象外（.gitignore で除外）。

# ============================================================
# バックエンド (FastAPI) — backend/.env
# ============================================================

# --- J-Quants API (V2) ---
# ダッシュボードの「設定 » API キー」で発行したキー。
# V2 はトークン2段階方式ではなく、このキーを x-api-key ヘッダーで送るだけ。
JQUANTS_API_KEY=your_jquants_api_key_here

# --- データベース ---
# SQLite ファイルのパス（リポジトリ直下の data/ を想定）。
DATABASE_PATH=./data/assetvane.db

# --- LLM (AI Advisor) ---
# アダプタで差し替え可能（OpenRouter 既定 / 将来 Ollama 等ローカル）。
# Tool Calling 対応モデルを指定すること（ADR-012）。
LLM_API_KEY=your_openrouter_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4-6

# --- API サーバ ---
# ラズパイで別端末のブラウザから見るため 0.0.0.0 で待ち受ける。
API_HOST=0.0.0.0
API_PORT=8000
# CORS 許可オリジン（フロントの URL）。カンマ区切り。
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- 通知 (Discord) --- ※Phase 6 で使用
# Discord チャンネルの Webhook URL。バッチ失敗時のエラー通知にも使う。
DISCORD_WEBHOOK_URL=

# --- 米国ETF/指数データソース --- ※Phase 7 で使用（任意・将来用）
# リードラグ戦略・米国株拡張で使用（ソース未確定）。
# US_EQUITY_SOURCE=stooq

# ============================================================
# フロントエンド (Next.js) — frontend/.env.local
# ============================================================
# NEXT_PUBLIC_* はブラウザに露出するため、秘密情報は置かない。
# FastAPI の場所（ラズパイなら http://raspberrypi.local:8000 等）。
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
