# AssetVane 環境変数テンプレート
#
# バックエンド: このファイルをコピーして backend/.env を作成し、実際の値を記入する:
#   cp .env.example backend/.env
# フロントエンド: frontend/.env.local に NEXT_PUBLIC_* を記入する（末尾参照）。
# .env 本体は git 管理対象外（.gitignore で除外）。

# ============================================================
# バックエンド (FastAPI) — backend/.env
# ============================================================

# --- J-Quants API (V2) ---
# ダッシュボードの「設定 » API キー」で発行したキー。
# V2 はトークン2段階方式ではなく、このキーを x-api-key ヘッダーで送るだけ。
JQUANTS_API_KEY=your_jquants_api_key_here

# --- データベース ---
# SQLite ファイルのパス（リポジトリ直下の data/ を想定）。
DATABASE_PATH=./data/assetvane.db

# --- LLM (AI Advisor) ---
# provider/api_key/base_url/model と面別割当は DB に移管し、起動後に /settings の WebUI で登録・編集
# する（ADR-058）。env には接続パラメータとコストガードだけ残す（既定は backend/app/config.py）。
# 複数 provider（OpenRouter / OpenAI 直 / ローカル LLM / Sakana 等・OpenAI 互換）を登録し、面
# （chat/nightly/dossier/tagger）ごとに provider と model を割り当てられる。
# ＊migration 後、初回は /settings で provider を登録するまで鍵あり面の LLM は動かない（codex は
#   鍵なし組み込みなので最初から使える）。
# LLM_TIMEOUT_SECONDS=60.0
# LLM_MAX_RETRIES=3
# LLM_COST_LIMIT_USD=50.0
# LLM_COST_GUARD_MODE=warn   # off / warn（既定） / block

# --- API サーバ ---
# ラズパイで別端末のブラウザから見るため 0.0.0.0 で待ち受ける。
# CORS 設定は廃止（ADR-037）。ブラウザは Next 同一オリジンの /api だけを叩き、Next の rewrites が
# 裏で backend へ素通しするため、backend に許可オリジンを置く必要が無い。
API_HOST=0.0.0.0
API_PORT=8000

# --- 通知 (Discord) --- ※Phase 6 で使用
# Discord チャンネルの Webhook URL。バッチ失敗時のエラー通知にも使う。
DISCORD_WEBHOOK_URL=

# --- 米国ETF/指数データソース --- ※Phase 7 で使用（任意・将来用）
# リードラグ戦略・米国株拡張で使用（ソース未確定）。
# US_EQUITY_SOURCE=stooq

# ============================================================
# フロントエンド (Next.js)
# ============================================================
# 同一オリジン化（ADR-037）で frontend に API_URL を渡す必要は無くなった（相対パス /api を叩く）。
# Next の rewrites 転送先だけ環境で変えられる（既定 http://backend:8000・compose 無しの
# ホスト直 dev は未設定で http://localhost:8000 に落ちる）。通常は設定不要。
# BACKEND_ORIGIN=http://backend:8000
