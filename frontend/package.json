{
  "name": "assetvane-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "AssetVane frontend — Next.js (App Router) UI のみ。DB には触らず REST 経由（ADR-005）",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "lightweight-charts": "^5.2.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0"
  },
  "//overrides": "Next が内部バンドルする postcss の advisory(GHSA-qx2v-qp2m-jg93) 回避。audit fix --force は next@9 への破滅的ダウングレードを提案するため使わず、安全パッチへピン留めする。",
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
