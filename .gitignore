# 環境変数（秘密情報）
.env
**/.env
!.env.example

# デプロイ設定（ローカル・PI_HOST / API_URL 等。雛形 deploy.env.example は追跡する）
/deploy.env

# データベース・データ
data/
*.db
*.db-wal
*.db-shm

# 機械学習モデル（Phase 5・別 PC 産・git 管理外。bind mount 先のディレクトリだけ .gitkeep で残す）
*.pkl
backend/models/*
!backend/models/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# Node / Next.js
node_modules/
.next/
out/
npm-debug.log*
*.tsbuildinfo

# 作業用一時ファイル（モック・スクラッチ）
.tmp/

# OS / エディタ
.DS_Store
.idea/
.vscode/

# Playwright MCP の検証成果物（スナップショット・スクショ・コンソールログ）
.playwright-mcp/
