# AssetVane backend 設定例（秘密は実 .env にだけ書く・ADR-005）。
# 既定値は app/config.py。ここはよく触るキーの早見表。コピーして .env を作る。

# --- J-Quants API (V2・x-api-key・ADR-008) --- Phase 0〜
JQUANTS_API_KEY=

# --- DB ---
DATABASE_PATH=./data/assetvane.db

# --- LLM (AI Advisor・OpenAI 互換) --- Phase 3〜
# provider/api_key/base_url/model と面別割当（chat/nightly/dossier/tagger）は DB に移管し、
# /settings の WebUI から登録・編集する（ADR-058）。env には接続パラメータとコストガードだけ残す。
# ＊migration 後、初回は /settings で provider を登録するまで鍵あり面の LLM は動かない（codex は
#   鍵なし組み込みなので最初から使える）。
LLM_TIMEOUT_SECONDS=60.0
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_SECONDS=2.0
# コストガード（ADR-028）: off / warn（既定） / block。OpenRouter 以外は cost を返さず 0 計上＝
# ガードが空洞化する点に注意（ADR-058）。
LLM_COST_LIMIT_USD=50.0
LLM_COST_GUARD_MODE=warn

# --- codex app-server（面の provider に codex を選んだとき・ADR-058） ---
# codex はプロセス設定だけ env に残す（model は面別に /settings で指定・空ならこの CODEX_MODEL）。
# 要 `codex login`（ChatGPT・API キー不要）。無人 cron のトークン継続に制約がある点に注意。
CODEX_BIN=codex
CODEX_MODEL=gpt-5.5
# 推論努力レベル（none/minimal/low/medium/high/xhigh）。空なら codex/モデル既定に任せる。
CODEX_REASONING_EFFORT=
CODEX_SANDBOX=read-only
# FastAPI 内 MCP の URL。codex がここへ接続して自前 Tool を呼ぶ（DB は FastAPI に閉じる）。
CODEX_MCP_URL=http://localhost:8000/mcp
CODEX_STARTUP_TIMEOUT_SECONDS=20.0
CODEX_TIMEOUT_SECONDS=180.0
CODEX_MAX_RETRIES=2

# --- API サーバ ---
# CORS 設定は廃止（ADR-037）。ブラウザは Next 同一オリジンの /api だけを叩き、Next の rewrites が
# 裏で backend へ素通しするため、backend 側に許可オリジンを置く必要が無い（ホスト一致の悩みが消えた）。
API_HOST=0.0.0.0
API_PORT=8000

# --- 通知 (Discord・ADR-007) --- Phase 6〜
DISCORD_WEBHOOK_URL=

# --- 通知 digest（Phase 6 Signal Beacon・phase6-spec §3） ---
# 夜間バッチ末尾の notify_digest が⑦⑧＋夜AI 提案を 1 通に束ねて送る。閾値は後から差替可。
ALERT_SCORE_MIN=0.6
ALERT_TOP_N=10
REBALANCE_ALERT_DAYS=14
ALWAYS_DAILY_DIGEST=true

# --- 夜間バッチ / cron（ADR-011/021） --- Phase 1〜
BATCH_SCHEDULER_ENABLED=false
BATCH_CRON_HOUR=2
BATCH_CRON_MINUTE=0
BATCH_TZ=Asia/Tokyo
BACKFILL_YEARS=2
# J-Quants の契約プラン。許容値は free or light（秒数はコードが決める：free=16s / light=1s）。
JQUANTS_PLAN=free

# --- IndexAdapter（Stooq・ADR-010） --- Phase 2〜
INDEX_SOURCE=stooq
INDEX_SYMBOLS=^SPX,^NKX,^TPX
INDEX_MIN_INTERVAL_SECONDS=1.0

# --- NewsAdapter（fetch_news 実取得・ADR-010/ADR-020） --- Phase 4
# httpx 一本（Google News RSS → URL 復元 → trafilatura 本文 → 記事ごと AI 要約 → 本文破棄）。
NEWS_ENABLED=true
NEWS_MAX_ARTICLES_PER_STOCK=10
NEWS_HTTP_TIMEOUT_SECONDS=20.0
NEWS_MIN_INTERVAL_SECONDS=1.0
GOOGLE_NEWS_BASE_URL=https://news.google.com
GOOGLE_NEWS_LANG=ja
GOOGLE_NEWS_COUNTRY=JP

# --- 銘柄別調査 cadence（夜の巡回・ADR-033） --- Phase 4
# 各銘柄の調査間隔は watchlist.interval_days（既定 21）。下は夜あたりの処理本数の天井。
DOSSIER_NIGHTLY_MAX=3
