# AssetVane backend 設定例（秘密は実 .env にだけ書く・ADR-005）。
# 既定値は app/config.py。ここはよく触るキーの早見表。コピーして .env を作る。

# --- J-Quants API (V2・x-api-key・ADR-008) --- Phase 0〜
# api_key と契約プランは env ではなく DB（jquants_config）＋ /settings の「J-Quants 設定」で管理する
# （ADR-061）。env からは撤去した（JQUANTS_API_KEY / JQUANTS_PLAN は廃止）。

# --- DB ---
DATABASE_PATH=./data/assetvane.db
# デプロイ前バックアップ（VACUUM INTO・ADR-017）で残す世代数。古いものは prune する。
BACKUP_KEEP=3

# --- ログ（ADR-038） ---
# logging root レベル（case-insensitive）。人間が読めるテキストで stdout へ。
LOG_LEVEL=INFO

# --- LLM (AI Advisor・OpenAI 互換) --- Phase 3〜
# provider/api_key/base_url/model と面別割当（chat/nightly/dossier/tagger）は DB に移管し、
# /settings の WebUI から登録・編集する（ADR-058）。env には接続パラメータとコストガードだけ残す。
# ＊migration 後、初回は /settings で provider を登録するまで LLM は動かない。
LLM_TIMEOUT_SECONDS=60.0
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_SECONDS=2.0
# コストガード（ADR-028）: off / warn（既定） / block。OpenRouter 以外は cost を返さず 0 計上＝
# ガードが空洞化する点に注意（ADR-058）。
LLM_COST_LIMIT_USD=50.0
LLM_COST_GUARD_MODE=warn

# --- Embedding（ニュース意味検索・OpenAI 互換 1 本・ADR-045/012/059） --- Phase 4〜
# base_url / api_key / model / dim は DB（embedding_config・/settings で編集）へ移管した（ADR-059）。
# env には接続パラメータ（timeout）だけ残す。3 キーが揃って初めて有効＝欠ければ静かに機能オフ。
EMBEDDING_TIMEOUT_SECONDS=30.0

# --- API サーバ ---
# CORS 設定は廃止（ADR-037）。ブラウザは Next 同一オリジンの /api だけを叩き、Next の rewrites が
# 裏で backend へ素通しするため、backend 側に許可オリジンを置く必要が無い（ホスト一致の悩みが消えた）。
API_HOST=0.0.0.0
API_PORT=8000

# --- 通知 (Discord・ADR-007) --- Phase 6〜
DISCORD_WEBHOOK_URL=

# --- 通知 digest（Phase 6 Signal Beacon・phase6-spec §3） ---
# 夜間バッチ末尾の notify_digest が⑦⑧＋夜AI 提案を 1 通に束ねて送る。閾値は後から差替可。
ALERT_SCORE_MIN=0.6
ALERT_TOP_N=10
REBALANCE_ALERT_DAYS=14
ALWAYS_DAILY_DIGEST=true

# --- 夜間バッチ / cron（ADR-011/021） --- Phase 1〜
BATCH_SCHEDULER_ENABLED=false
BATCH_CRON_HOUR=2
BATCH_CRON_MINUTE=0
BATCH_TZ=Asia/Tokyo
BACKFILL_YEARS=2

# --- IndexAdapter（主要指数・フォールバック連鎖・ADR-010） --- Phase 2〜
# カンマ区切り・優先順（adapters/index.py の _REGISTRY が解決・未知名は skip）。Yahoo 主・Stooq
# フォールバック・jquants は ^TPX 専用の最後段（Free では TOPIX は 403）。
INDEX_SOURCES=yahoo,stooq,jquants
INDEX_SYMBOLS=^SPX,^NKX,^TPX
INDEX_MIN_INTERVAL_SECONDS=1.0

# --- FundNavAdapter（投信 NAV・基準価額・ADR-010/054） --- Phase 2/投信保有管理
FUND_NAV_BASE_URL=https://toushin-lib.fwg.ne.jp
FUND_NAV_MIN_INTERVAL_SECONDS=1.0
FUND_NAV_HTTP_TIMEOUT_SECONDS=30.0

# --- NewsAdapter（fetch_news 実取得・ADR-010/ADR-020） --- Phase 4
# httpx 一本（Google News RSS → URL 復元 → trafilatura 本文 → 記事ごと AI 要約 → 本文破棄）。
NEWS_ENABLED=true
NEWS_MAX_ARTICLES_PER_STOCK=10
NEWS_HTTP_TIMEOUT_SECONDS=20.0
NEWS_MIN_INTERVAL_SECONDS=1.0
GOOGLE_NEWS_BASE_URL=https://news.google.com
GOOGLE_NEWS_LANG=ja
GOOGLE_NEWS_COUNTRY=JP

# --- 銘柄別調査 cadence（夜の巡回・ADR-033） --- Phase 4
# 各銘柄の調査間隔は watchlist.interval_days（既定 21）。下は夜あたりの処理本数の天井。
DOSSIER_NIGHTLY_MAX=3

# --- AI Alpha Scorer（学習済み .pkl の置き場・ADR-006） --- Phase 5
# 別 PC 産の .pkl とメタ JSON の置き場（git 管理外・compose で bind mount）。モデル無時は静かに skip。
ML_MODEL_DIR=./models

# --- UsEquityAdapter（米国株スクリーナー・yfinance 一本・ADR-010/055） --- Phase 7(B-1)
# 提示専用（JPY 資産評価コアに無改変）。秘密情報は不要（yfinance は無認証）。
US_EQUITY_SOURCE=yahoo
US_EQUITY_MIN_INTERVAL_SECONDS=1.0
US_UNIVERSE_BASE_URL=https://www.nasdaqtrader.com
US_EQUITY_HTTP_TIMEOUT_SECONDS=30.0
# fundamentals（`.info`）低頻度ローテ巡回の夜あたり天井／OHLCV まとめ取得の分割幅。
US_FUNDAMENTALS_NIGHTLY_MAX=900
US_QUOTES_BATCH_SIZE=50

# --- FxAdapter（FX レート・米株保有の JPY 合算・yfinance JPY=X・ADR-010/057） --- Phase 7(B-2)
FX_SOURCE=yahoo
FX_MIN_INTERVAL_SECONDS=1.0
FX_HTTP_TIMEOUT_SECONDS=30.0

# --- テーマタグ（grounded 事前タグ・ADR-050/056） --- Phase 7
# 夜あたりタグ付け本数の天井（暴走防止）。US 段階A／JP 段階B でそれぞれ消費。
THEME_TAGGING_NIGHTLY_MAX=150
THEME_TAGGING_JP_NIGHTLY_MAX=100
# stock_themes の時間窓 prune（最終再確認 last_seen_at からの日数）。ローテ一周日数より十分大きく保つ。
THEME_PRUNE_DAYS=90

# --- EDINET（有報「事業の内容」・テーマタグ段階C・ADR-010/056） --- Phase 7
# 無料登録で発行される Subscription-Key（金融庁 EDINET API v2）。テキスト専用の additive ソースで
# 価格/財務は J-Quants のまま（ADR-008）。未設定なら段階C（JP 全ユニバースのテーマタグ）は静かに機能オフ。
EDINET_API_KEY=
EDINET_BASE_URL=https://api.edinet-fsa.go.jp/api/v2
EDINET_HTTP_TIMEOUT_SECONDS=30.0
EDINET_MIN_INTERVAL_SECONDS=1.0
# 夜あたり要約する有報の天井／バックフィル script の遡及窓（約 470 日＝15ヶ月で年次サイクル 1 周）。
EDINET_NIGHTLY_MAX=100
EDINET_BACKFILL_WINDOW_DAYS=470
